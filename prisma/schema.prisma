generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role      String   @default("STAFF")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@map("users")
}

model Student {
  id          Int      @id @default(autoincrement())
  admissionNo String?  @unique
  firstName   String
  lastName    String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  admissions  Admission[]
  invoices    FeeInvoice[]
  payments    FeePayment[]
  leaves      LeaveRequest[]

  @@index([status])
  @@map("students")
}

model Admission {
  id         Int      @id @default(autoincrement())
  studentId  Int
  admittedAt DateTime @default(now())
  admitYm    String

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([admittedAt])
  @@index([admitYm])
  @@index([studentId])
  @@map("admissions")
}

model ApprovalRequest {
  id         Int       @id @default(autoincrement())
  type       String
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([type])
  @@map("approval_requests")
}

model LeaveRequest {
  id        Int      @id @default(autoincrement())
  studentId Int
  fromDate  DateTime
  toDate    DateTime
  reason    String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@index([studentId])
  @@map("leave_requests")
}

model FeeInvoice {
  id          Int      @id @default(autoincrement())
  studentId   Int
  issueDate   DateTime @default(now())
  dueDate     DateTime?
  totalAmount Float
  status      String   @default("ISSUED")

  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments    FeePayment[]

  @@index([studentId])
  @@index([issueDate])
  @@index([status])
  @@map("fee_invoices")
}

model FeePayment {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  studentId Int
  paidAt    DateTime @default(now())
  amount    Float
  status    String   @default("SUCCESS")
  method    String?
  reference String?
  paidYm    String

  invoice   FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([paidAt])
  @@index([paidYm])
  @@index([status])
  @@index([invoiceId])
  @@index([studentId])
  @@map("fee_payments")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int
  meta      String?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}