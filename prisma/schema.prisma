generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  TEACHER
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum FeeStatus {
  ISSUED
  PARTIALLY_PAID
  PENDING
  PAID
  OVERDUE
  WAIVED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role       UserRole @default(STAFF)
  status     String   @default("ACTIVE")
  department String?
  activeStatuses StaffActiveStatus[]
  staffLeaves    StaffLeaveRequest[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@map("users")
}

model StaffActiveStatus {
  id         Int @id @default(autoincrement())
  staffId    Int
  markedDate DateTime
  status     StaffStatus
  markedAt   DateTime @default(now())
  markedBy   Int?

  staff User @relation(fields: [staffId], references: [id])

  @@unique([staffId, markedDate])
  @@index([staffId, markedDate])
  @@map("staff_active_status")
}

model Student {
  id          Int      @id @default(autoincrement())
  admissionNo String?  @unique
  firstName   String
  lastName    String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  admissions  Admission[]
  invoices    FeeInvoice[]
  payments    FeePayment[]
  leaves      LeaveRequest[]
  attendance  StudentAttendance[]

  @@index([status])
  @@map("students")
}

model StudentAttendance {
  id         Int      @id @default(autoincrement())
  studentId  Int
  markedDate DateTime
  status     String   // "PRESENT", "ABSENT", "LATE"
  markedAt   DateTime @default(now())
  markedBy   Int?

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, markedDate])
  @@index([studentId, markedDate])
  @@map("student_attendance")
}

model Admission {
  id         Int      @id @default(autoincrement())
  studentId  Int
  admittedAt DateTime @default(now())
  admitYm    String

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([admittedAt])
  @@index([admitYm])
  @@index([studentId])
  @@map("admissions")
}



model LeaveRequest {
  id        Int      @id @default(autoincrement())
  studentId Int
  fromDate  DateTime
  toDate    DateTime
  reason    String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  requestedAt DateTime @default(now())
  rejectionReason String?
  studentParentNotified Boolean @default(false)

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@index([studentId])
  @@index([studentId, status])
  @@map("leave_requests")
}

model StaffLeaveRequest {
  id         Int @id @default(autoincrement())
  staffId    Int
  fromDate   DateTime
  toDate     DateTime
  reason     String?
  status     String @default("PENDING")

  approvedBy Int?
  approvedAt DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  staff User @relation(fields: [staffId], references: [id])

  @@index([staffId])
  @@index([status])
  @@map("staff_leave_requests")
}

model LeaveApprovalRequest {
  id             Int @id @default(autoincrement())

  requestType    String

  linkedEntityId Int

  requestedBy    Int

  reviewedBy     Int?

  status         ApprovalStatus @default(PENDING)

  approvalNotes  String?

  createdAt      DateTime @default(now())

  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([createdAt, status])

  @@map("leave_approval_requests")
}

model FeeAdjustmentRequest {
  id               Int @id @default(autoincrement())

  invoiceId        Int

  requestedBy      Int

  reviewedBy       Int?

  requestType      String

  status           ApprovalStatus @default(PENDING)

  adjustmentAmount Float?

  approvalNotes    String?

  createdAt        DateTime @default(now())

  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt, status])

  @@map("fee_adjustment_requests")
}

model FeeInvoice {
  id          Int      @id @default(autoincrement())
  studentId   Int
  issueDate   DateTime @default(now())
  dueDate     DateTime?
  totalAmount Float
  status      FeeStatus @default(ISSUED)

  updatedBy   Int?
  fineAmount  Float @default(0)
  paidAmount  Float @default(0)

  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments    FeePayment[]

  @@index([studentId])
  @@index([issueDate])
  @@index([status])
  @@index([studentId, dueDate, status])
  @@map("fee_invoices")
}

model FeePayment {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  studentId Int
  paidAt    DateTime @default(now())
  amount    Float
  status    String   @default("SUCCESS")
  method    String?
  reference String?
  paidYm    String

  invoice   FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([paidAt])
  @@index([paidYm])
  @@index([status])
  @@index([invoiceId])
  @@index([studentId])
  @@map("fee_payments")
}

model FeePaymentLog {
  id              Int @id @default(autoincrement())

  invoiceId       Int

  paymentAmount   Float

  paymentMethod   String?

  updatedBy       Int?

  updatedAt       DateTime @default(now())

  adjustmentReason String?

  @@index([invoiceId])
  @@map("fee_payment_logs")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int
  meta      String?
  performedBy Int?
  changeDetails String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
model Role {
  id Int @id @default(autoincrement())
  name String @unique
  permissions RolePermission[]
}

model Permission {
  id Int @id @default(autoincrement())
  name String @unique
  roles RolePermission[]
}

model RolePermission {
  roleId Int
  permissionId Int

  role Role @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}