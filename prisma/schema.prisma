generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
}

enum ApprovalType {
  LEAVE
  FEE_ADJUSTMENT
  WAIVER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  ISSUED
  PAID
  VOID
}

enum PaymentStatus {
  SUCCESS
  FAILED
  REFUNDED
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String
  role      UserRole   @default(STAFF)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  leaveRequests LeaveApprovalRequest[] @relation("LeaveRequester")
  leaveReviews  LeaveApprovalRequest[] @relation("LeaveReviewer")
  feeRequests   FeeAdjustmentRequest[] @relation("FeeRequester")
  feeReviews    FeeAdjustmentRequest[] @relation("FeeReviewer")
  auditLogs     AuditLog[]
}

model Student {
  id          Int           @id @default(autoincrement())
  admissionNo String?       @unique
  firstName   String
  lastName    String
  status      StudentStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())

  admissions Admission[]
  invoices   FeeInvoice[]
  payments   FeePayment[]
  leaves     LeaveRequest[]
}

model Admission {
  id         Int      @id @default(autoincrement())
  studentId  Int
  admittedAt DateTime @default(now())
  admitYm    String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id        Int            @id @default(autoincrement())
  studentId Int
  fromDate  DateTime
  toDate    DateTime
  reason    String?
  status    ApprovalStatus @default(PENDING)
  createdAt DateTime       @default(now())

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  approvals LeaveApprovalRequest[]

  @@index([studentId, status])
}

model LeaveApprovalRequest {
  id            Int            @id @default(autoincrement())
  leaveId       Int
  requestedBy   Int
  reviewedBy    Int?
  requestType   ApprovalType   @default(LEAVE)
  status        ApprovalStatus @default(PENDING)
  approvalNotes String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  leave     LeaveRequest @relation(fields: [leaveId], references: [id], onDelete: Cascade)
  requester User         @relation("LeaveRequester", fields: [requestedBy], references: [id])
  reviewer  User?        @relation("LeaveReviewer", fields: [reviewedBy], references: [id])
}

model FeeInvoice {
  id          Int           @id @default(autoincrement())
  studentId   Int
  issueDate   DateTime      @default(now())
  dueDate     DateTime?
  totalAmount Float
  status      InvoiceStatus @default(ISSUED)

  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments    FeePayment[]
  adjustments FeeAdjustmentRequest[]

  @@index([studentId, dueDate, status])
}

model FeeAdjustmentRequest {
  id            Int            @id @default(autoincrement())
  invoiceId     Int
  requestedBy   Int
  reviewedBy    Int?
  requestType   ApprovalType   @default(FEE_ADJUSTMENT)
  status        ApprovalStatus @default(PENDING)
  approvalNotes String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  invoice   FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  requester User       @relation("FeeRequester", fields: [requestedBy], references: [id])
  reviewer  User?      @relation("FeeReviewer", fields: [reviewedBy], references: [id])
}

model FeePayment {
  id        Int           @id @default(autoincrement())
  invoiceId Int
  studentId Int
  paidAt    DateTime      @default(now())
  amount    Float
  status    PaymentStatus @default(SUCCESS)
  method    String?
  reference String?
  paidYm    String

  invoice FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  action        String
  entity        String
  entityId      Int
  performedBy   Int
  changeDetails Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  performer User @relation(fields: [performedBy], references: [id])
}